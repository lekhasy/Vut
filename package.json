{
  "name": "velucid",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "start": "nx serve web",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "preflight": "nx run-many -t lint typecheck test build --parallel && bunx nx format:check",
    "prepare": "git config core.hooksPath scripts/hooks"
  },
  "devDependencies": {
    "@nx/dotnet": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/node": "22.7.5",
    "@nx/workspace": "22.7.5",
    "eslint": "^9.0.0",
    "nx": "22.7.5",
    "prettier": "^3.3.0",
    "typescript": "5.8.3"
  }
}
