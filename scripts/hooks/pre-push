#!/usr/bin/env bash
# Pre-push hook: runs the same format / lint / typecheck / build checks as the
# CI nx-verify job, so we catch failures locally before the push lands in CI.
# We intentionally do NOT run `test` here — `apps/web:test` (Playwright e2e)
# requires a live Auth0 + silo + KurrentDB + Postgres stack that almost never
# exists on a dev machine. Run tests manually with:
#
#   bunx nx run-many -t test          # unit tests (fast; works in a clean checkout)
#   bunx nx run-many -t test --exclude web   # unit tests only (skip the e2e)
#   bun run preflight                 # full check (unit + e2e + format + build)
#
# Bypass with `git push --no-verify` if you need to push a WIP and accept the
# risk of a red CI run.

set -euo pipefail

# Find the workspace root (the directory that contains bun.lock) regardless
# of where git is invoked from.
WORKSPACE_ROOT="$(git rev-parse --show-toplevel)"
cd "$WORKSPACE_ROOT"

if ! command -v bun >/dev/null 2>&1; then
  echo "pre-push: bun is not on PATH; install it first (https://bun.sh)." >&2
  exit 1
fi

# Pre-warm dotnet's first-time-config BEFORE Nx spins up parallel dotnet
# invocations. On a fresh CI runner (and occasionally on a local checkout
# that has never run dotnet) the parallel `dotnet build` / `dotnet test` /
# `dotnet format` calls from `bunx nx run-many --parallel` race on the
# `NuGet-Migrations` named mutex, and the per-session shm directory under
# /tmp/.dotnet/shm/session{N} gets created twice — the second mkdir fails
# with EEXIST and the build aborts with:
#   System.IO.IOException: The system cannot open the device or file
#   specified. : 'NuGet-Migrations'.
# A single serial `dotnet --info` completes the migration once, so the
# parallel invocations skip it entirely.
if command -v dotnet >/dev/null 2>&1; then
  echo "pre-push: pre-warming dotnet (avoid NuGet-Migrations mutex race)..."
  dotnet --info > /dev/null 2>&1 || true
fi

echo "pre-push: format:check..."
if ! bunx nx format:check; then
  echo "pre-push: format:check failed. Run \`bunx nx format:write\` and re-stage." >&2
  exit 1
fi

echo "pre-push: lint, typecheck, build (skipping test — see comment at top)..."
# Mirror the CI nx-verify gate + add build (so we catch things like a
# --no-restore regression in a dotnet typecheck target). Nx's local cache
# means unchanged projects re-run in <1s; changed projects pay full cost.
if ! bunx nx run-many -t lint typecheck build --parallel; then
  echo "pre-push: at least one check failed. Fix the errors above and retry." >&2
  echo "pre-push: (bypass with \`git push --no-verify\` if you accept a red CI.)" >&2
  exit 1
fi

echo "pre-push: all checks passed. Pushing..."
