# VUT Platform - Development Environment Variables
# This file is loaded by docker compose when VUT_ENV=dev or unset

# ─── General ──────────────────────────────────────────────────────
VUT_ENV=dev

# ─── KurrentDB ────────────────────────────────────────────────────
KURRENTDB_HTTP_PORT=2113
KURRENTDB_TCP_PORT=1113
KURRENTDB_CLUSTER_SIZE=1
KURRENTDB_MEMORY_LIMIT=3G
KURRENTDB_MEMORY_RESERVATION=1G
KURRENTDB_CONNECTION_STRING=esdb://kurrentdb:2113?tls=false

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRESQL_PORT=5432
POSTGRESQL_USER=vut_app
POSTGRESQL_PASSWORD=vut_dev_password
POSTGRESQL_MEMORY_LIMIT=2G
POSTGRESQL_MEMORY_RESERVATION=512M
POSTGRESQL_CONNECTION_STRING=Host=postgresql;Database=vut_readmodel;Username=vut_app;Password=vut_dev_password

# ─── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_PORT=8081
PGADMIN_EMAIL=admin@vut.dev
PGADMIN_PASSWORD=admin
PGADMIN_MEMORY_LIMIT=512M
PGADMIN_MEMORY_RESERVATION=128M

# ─── Actor Service ────────────────────────────────────────────────
ACTOR_SERVICE_PORT=5000
ACTOR_SERVICE_GRPC_PORT=5001
ACTOR_SERVICE_MEMORY_LIMIT=1G
ACTOR_SERVICE_MEMORY_RESERVATION=256M
ACTOR_SERVICE_URL=http://actor-service:5000
ASPNETCORE_ENVIRONMENT=Development

# ─── Orleans ─────────────────────────────────────────────────────
ORLEANS_CLUSTER_ID=vut-cluster
ORLEANS_SERVICE_ID=vut-service
ORLEANS_CLUSTERING_CONNECTION_STRING=Host=postgresql;Database=vut_readmodel;Username=vut_app;Password=vut_dev_password
ORLEANS_DASHBOARD_PORT=8888

# ─── Frontend ─────────────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_MEMORY_LIMIT=512M
FRONTEND_MEMORY_RESERVATION=128M
READMODEL_URL=http://actor-service:5001

# ─── Auth0 (Development) ─────────────────────────────────────────
# Replace with your Auth0 dev tenant values
AUTH0_DOMAIN=dev-vut.us.auth0.com
AUTH0_AUDIENCE=https://vut-api-dev
AUTH0_CLIENT_ID=YOUR_DEV_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_DEV_CLIENT_SECRET
