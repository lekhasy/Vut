# Velucid Platform - Development Environment Variables
# This file is loaded by docker compose when VELUCID_ENV=dev or unset

# ─── General ──────────────────────────────────────────────────────
VELUCID_ENV=dev

# ─── KurrentDB ────────────────────────────────────────────────────
KURRENTDB_HTTP_PORT=2113
KURRENTDB_TCP_PORT=1113
KURRENTDB_CLUSTER_SIZE=1
KURRENTDB_MEMORY_LIMIT=3G
KURRENTDB_MEMORY_RESERVATION=1G
KURRENTDB_CONNECTION_STRING=esdb://kurrentdb:2113?tls=false

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRESQL_PORT=5432
POSTGRESQL_USER=velucid_app
POSTGRESQL_PASSWORD=velucid_dev_password
POSTGRESQL_MEMORY_LIMIT=2G
POSTGRESQL_MEMORY_RESERVATION=512M
POSTGRESQL_CONNECTION_STRING=Host=postgresql;Database=velucid_readmodel;Username=velucid_app;Password=velucid_dev_password

# ─── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_PORT=8081
PGADMIN_EMAIL=admin@velucid.dev
PGADMIN_PASSWORD=admin
PGADMIN_MEMORY_LIMIT=512M
PGADMIN_MEMORY_RESERVATION=128M

# ─── Silo (Orleans backend — API + Grains co-hosted) ─────────────
SILO_API_PORT=5000
SILO_SILO_PORT=11111
SILO_GATEWAY_PORT=30000
SILO_MEMORY_LIMIT=1G
SILO_MEMORY_RESERVATION=256M
SILO_API_URL=http://silo:5000
ASPNETCORE_ENVIRONMENT=Development

# ─── Projector Service (background worker) ───────────────────────
PROJECTOR_SERVICE_MEMORY_LIMIT=512M
PROJECTOR_SERVICE_MEMORY_RESERVATION=128M

# ─── Orleans ─────────────────────────────────────────────────────
ORLEANS_CLUSTER_ID=velucid-cluster
ORLEANS_SERVICE_ID=velucid
ORLEANS_DASHBOARD_PORT=8888

# ─── Frontend ─────────────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_MEMORY_LIMIT=512M
FRONTEND_MEMORY_RESERVATION=128M
NODE_ENV=development
# PUBLIC_API_BASE_URL - leave empty for relative URLs (same-origin API calls)
PUBLIC_API_BASE_URL=

# ─── Auth0 (Development) ─────────────────────────────────────────
# Replace with your Auth0 dev tenant values
AUTH0_DOMAIN=dev-velucid.us.auth0.com
AUTH0_AUDIENCE=https://velucid-api-dev
AUTH0_CLIENT_ID=YOUR_DEV_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_DEV_CLIENT_SECRET

# ─── Resend (Email API — Development) ────────────────────────────
# Replace with your Resend API key from https://resend.com/api-keys
RESEND_API_KEY=YOUR_DEV_RESEND_API_KEY
