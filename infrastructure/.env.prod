# VUT Platform - Production Environment Variables
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
#
# IMPORTANT: Replace all placeholder values before deploying to production.
# Consider using Docker secrets or a secrets manager for sensitive values.

# ─── General ──────────────────────────────────────────────────────
VUT_ENV=prod

# ─── KurrentDB ────────────────────────────────────────────────────
KURRENTDB_HTTP_PORT=2113
KURRENTDB_TCP_PORT=1113
KURRENTDB_CLUSTER_SIZE=1
KURRENTDB_MEMORY_LIMIT=8G
KURRENTDB_MEMORY_RESERVATION=4G
KURRENTDB_CONNECTION_STRING=esdb://kurrentdb:2113?tls=false

# ─── Redpanda ─────────────────────────────────────────────────────
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_SMP=2
REDPANDA_MEMORY=4G
REDPANDA_MEMORY_LIMIT=4G
REDPANDA_MEMORY_RESERVATION=2G
REDPANDA_BOOTSTRAP_SERVERS=redpanda:9092

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRESQL_PORT=5432
POSTGRESQL_USER=vut_prod
POSTGRESQL_PASSWORD=CHANGE_ME_PROD_PASSWORD_USE_SECRETS_MANAGER
POSTGRESQL_MEMORY_LIMIT=8G
POSTGRESQL_MEMORY_RESERVATION=2G
POSTGRESQL_CONNECTION_STRING=Host=postgresql;Database=vut_readmodel;Username=vut_prod;Password=CHANGE_ME_PROD_PASSWORD_USE_SECRETS_MANAGER

# ─── Redpanda Console ─────────────────────────────────────────────
REDPANDA_CONSOLE_PORT=8080
REDPANDA_CONSOLE_MEMORY_LIMIT=1G
REDPANDA_CONSOLE_MEMORY_RESERVATION=256M

# ─── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_PORT=8081
PGADMIN_EMAIL=admin@vut.prod
PGADMIN_PASSWORD=CHANGE_ME_PROD_PGADMIN
PGADMIN_MEMORY_LIMIT=1G
PGADMIN_MEMORY_RESERVATION=256M

# ─── Actor Service ────────────────────────────────────────────────
ACTOR_SERVICE_PORT=5000
ACTOR_SERVICE_GRPC_PORT=5001
ACTOR_SERVICE_MEMORY_LIMIT=4G
ACTOR_SERVICE_MEMORY_RESERVATION=1G
ACTOR_SERVICE_URL=http://actor-service:5000
ASPNETCORE_ENVIRONMENT=Production
PROTOACTOR_CLUSTER_PROVIDER=Redpanda
PROTOACTOR_REDPANDA_BOOTSTRAP_SERVERS=redpanda:9092

# ─── Frontend ─────────────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_MEMORY_LIMIT=1G
FRONTEND_MEMORY_RESERVATION=512M
READMODEL_URL=http://actor-service:5001

# ─── Auth0 (Production) ──────────────────────────────────────────
# IMPORTANT: Use production Auth0 tenant and rotate these credentials regularly
AUTH0_DOMAIN=vut.us.auth0.com
AUTH0_AUDIENCE=https://vut-api-prod
AUTH0_CLIENT_ID=YOUR_PROD_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_PROD_CLIENT_SECRET
