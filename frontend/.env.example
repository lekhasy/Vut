# Auth0 Configuration
AUTH0_DOMAIN=xxx.us.auth0.com
AUTH0_CLIENT_ID=abc123
AUTH0_CLIENT_SECRET=secret123
AUTH0_AUDIENCE=https://api.velucid.dev

# Session encryption key (32 bytes, base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Co-hosted silo API URL
SILO_API_URL=http://velucid-silo:5000

# Application base URL (no trailing slash)
APP_URL=http://localhost:3000
