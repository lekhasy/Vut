---
interface Props {
  label?: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  id?: string;
  name?: string;
  value?: string;
  error?: string;
  class?: string;
}

const {
  label,
  type = 'text',
  placeholder,
  required = false,
  disabled = false,
  id,
  name,
  value,
  error,
  class: className = '',
} = Astro.props;
---

<div class:list={['flex flex-col gap-1.5', className]}>
  {label && (
    <label for={id} class="text-sm font-medium text-[var(--color-text)]">
      {label}
      {required && <span class="text-red-500 ml-0.5">*</span>}
    </label>
  )}
  <input
    type={type}
    id={id}
    name={name}
    value={value}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    class:list={[
      'w-full rounded-lg border px-3 py-2 text-sm bg-[var(--color-bg)] text-[var(--color-text)] placeholder-[var(--color-text-secondary)]',
      'focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500',
      'disabled:opacity-50 disabled:cursor-not-allowed',
      error ? 'border-red-500' : 'border-[var(--color-border)]',
    ]}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={error && id ? `${id}-error` : undefined}
  />
  {error && (
    <p id={id ? `${id}-error` : undefined} class="text-sm text-red-500" role="alert">
      {error}
    </p>
  )}
</div>
