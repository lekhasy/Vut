---
import crypto from 'node:crypto';
import { buildAuthorizationUrl } from '@/lib/auth/auth0';

const state = crypto.randomBytes(32).toString('hex');

Astro.cookies.set('oauth_state', state, {
  httpOnly: true,
  secure: true,
  sameSite: 'lax',
  path: '/',
  maxAge: 600, // 10 minutes
});

return Astro.redirect(buildAuthorizationUrl(state), 302);
---
