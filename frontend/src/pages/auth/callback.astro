---
import { exchangeCodeForTokens } from '@/lib/auth/auth0';
import { validateIdToken } from '@/lib/auth/jwt';
import {
  encrypt,
  buildSessionCookieHeader,
  type SessionPayload,
} from '@/lib/auth/session';

const url = Astro.url;
const code = url.searchParams.get('code');
const state = url.searchParams.get('state');
const error = url.searchParams.get('error');

// Auth0 returned an error
if (error) {
  console.error('Auth0 error:', error, url.searchParams.get('error_description'));
  return Astro.redirect('/auth/login', 302);
}

// Missing required parameters
if (!code || !state) {
  return Astro.redirect('/auth/login', 302);
}

// Validate state against cookie
const storedState = Astro.cookies.get('oauth_state')?.value;
Astro.cookies.delete('oauth_state', { path: '/' });

if (!storedState || storedState !== state) {
  console.error('OAuth state mismatch');
  return Astro.redirect('/auth/login', 302);
}

try {
  // Exchange code for tokens
  const tokens = await exchangeCodeForTokens(code);

  // Validate ID token JWT
  const claims = await validateIdToken(tokens.id_token);

  // Extract user info from claims
  const providerId = claims.sub;
  const providerName = providerId.split('|')[0];
  const displayName = claims.name ?? claims.nickname ?? 'User';
  const avatarUrl = claims.picture ?? '';
  const email = claims.email ?? null;

  const siloApiUrl = import.meta.env.SILO_API_URL;

  // Look up user by providerId
  let userId: string | null = null;
  let isEmailVerified = false;

  const lookupRes = await fetch(
    `${siloApiUrl}/api/users/by-provider/${encodeURIComponent(providerId)}`,
  );

  if (lookupRes.ok) {
    // Existing user found
    const userData = await lookupRes.json();
    userId = userData.userId;
    isEmailVerified = userData.isEmailVerified ?? false;
  } else if (lookupRes.status === 404) {
    // User not found — try auto-linking by email or create new user
    if (email) {
      const emailLookupRes = await fetch(
        `${siloApiUrl}/api/users/by-email/${encodeURIComponent(email)}`,
      );

      if (emailLookupRes.ok) {
        // Existing user found by email — link the new identity
        const existingUser = await emailLookupRes.json();
        userId = existingUser.userId;
        isEmailVerified = existingUser.isEmailVerified ?? false;

        await fetch(`${siloApiUrl}/api/users/${userId}/link-identity`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ providerId, providerName, email }),
        });
      }
    }

    if (!userId) {
      // Truly new user — create
      const createRes = await fetch(`${siloApiUrl}/api/users/create`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          providerId,
          providerName,
          displayName,
          avatarUrl,
          email,
        }),
      });

      if (!createRes.ok) {
        const errBody = await createRes.text();
        throw new Error(`User creation failed (${createRes.status}): ${errBody}`);
      }

      const created = await createRes.json();
      userId = created.userId;
      isEmailVerified = false;
    }
  } else {
    throw new Error(`User lookup failed (${lookupRes.status})`);
  }

  // Build session payload and set encrypted cookie
  const sessionPayload: SessionPayload = {
    userId: userId!,
    providerId,
    displayName,
    avatarUrl,
    isEmailVerified,
    iat: Math.floor(Date.now() / 1000),
  };

  const encryptedSession = encrypt(sessionPayload);
  const cookieHeader = buildSessionCookieHeader(encryptedSession);

  // Redirect based on email verification status
  const redirectTo = isEmailVerified ? '/dashboard' : '/verify-email';

  return new Response(null, {
    status: 302,
    headers: {
      Location: redirectTo,
      'Set-Cookie': cookieHeader,
    },
  });
} catch (err) {
  console.error('Auth callback error:', err);
  return Astro.redirect('/auth/login', 302);
}
---
