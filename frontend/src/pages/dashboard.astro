---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Dashboard" pageTitle="Auth API">
  <div class="board">
    <!-- Board toolbar -->
    <div class="toolbar">
      <div class="toolbar-left">
        <span class="toolbar-label">Sprint 4</span>
        <span class="toolbar-divider"></span>
        <span class="toolbar-meta">Jun 2 — Jun 16</span>
      </div>
      <div class="toolbar-right">
        <button class="toolbar-btn" title="Filter">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
        </button>
        <button class="toolbar-btn" title="Members">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </button>
      </div>
    </div>

    <!-- Columns -->
    <div class="columns">

      <!-- Backlog -->
      <div class="column">
        <div class="column-header">
          <h3 class="column-title">
            <span class="column-dot column-dot--slate"></span>
            Backlog
            <span class="column-count">5</span>
          </h3>
        </div>
        <div class="column-cards">
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
              <span class="card-priority card-priority--low">Low</span>
            </div>
            <p class="card-title">Rate limiting on public endpoints</p>
            <div class="card-bottom">
              <span class="card-id">VEL-012</span>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--bug">Bug</span>
              <span class="card-priority card-priority--med">Med</span>
            </div>
            <p class="card-title">Token refresh race condition</p>
            <div class="card-bottom">
              <span class="card-id">VEL-018</span>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
            </div>
            <p class="card-title">Webhook delivery retry queue</p>
            <div class="card-bottom">
              <span class="card-id">VEL-021</span>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--chore">Chore</span>
            </div>
            <p class="card-title">Upgrade to Node 22 LTS</p>
            <div class="card-bottom">
              <span class="card-id">VEL-024</span>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
            </div>
            <p class="card-title">Audit log export to CSV</p>
            <div class="card-bottom">
              <span class="card-id">VEL-027</span>
            </div>
          </div>
        </div>
      </div>

      <!-- In Progress -->
      <div class="column">
        <div class="column-header">
          <h3 class="column-title">
            <span class="column-dot column-dot--amber"></span>
            In Progress
            <span class="column-count">2</span>
          </h3>
        </div>
        <div class="column-cards">
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
              <span class="card-priority card-priority--high">High</span>
            </div>
            <p class="card-title">OAuth2 PKCE flow for mobile clients</p>
            <div class="card-footer">
              <span class="card-id">VEL-009</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
              <span class="card-priority card-priority--med">Med</span>
            </div>
            <p class="card-title">Dashboard kanban board view</p>
            <div class="card-footer">
              <span class="card-id">VEL-015</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
        </div>
      </div>

      <!-- In Review -->
      <div class="column">
        <div class="column-header">
          <h3 class="column-title">
            <span class="column-dot column-dot--purple"></span>
            In Review
            <span class="column-count">2</span>
          </h3>
        </div>
        <div class="column-cards">
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
            </div>
            <p class="card-title">Session encryption with AES-256-GCM</p>
            <div class="card-footer">
              <span class="card-id">VEL-007</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="card-tag card-tag--bug">Bug</span>
              <span class="card-priority card-priority--high">High</span>
            </div>
            <p class="card-title">CORS preflight on /api/auth/*</p>
            <div class="card-footer">
              <span class="card-id">VEL-014</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Done -->
      <div class="column">
        <div class="column-header">
          <h3 class="column-title">
            <span class="column-dot column-dot--emerald"></span>
            Done
            <span class="column-count">3</span>
          </h3>
        </div>
        <div class="column-cards">
          <div class="card card--done">
            <div class="card-top">
              <span class="card-tag card-tag--feature">Feature</span>
            </div>
            <p class="card-title">Auth0 SSO integration</p>
            <div class="card-footer">
              <span class="card-id">VEL-001</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
          <div class="card card--done">
            <div class="card-top">
              <span class="card-tag card-tag--chore">Chore</span>
            </div>
            <p class="card-title">CI/CD pipeline with Docker build</p>
            <div class="card-footer">
              <span class="card-id">VEL-003</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
          <div class="card card--done">
            <div class="card-top">
              <span class="card-tag card-tag--bug">Bug</span>
            </div>
            <p class="card-title">Session cookie not clearing on logout</p>
            <div class="card-footer">
              <span class="card-id">VEL-005</span>
              <div class="card-avatar">SY</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</AppLayout>

<style>
  .board {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: calc(100vh - 3.5rem - 3rem);
  }

  /* ─── Toolbar ─────────────────────────────────── */
  .toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .toolbar-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .toolbar-divider {
    width: 1px;
    height: 1rem;
    background: var(--color-border);
  }

  .toolbar-meta {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
  }

  .toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .toolbar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem; height: 2rem;
    border-radius: 0.375rem;
    color: var(--color-text-secondary);
    transition: color 0.15s, background 0.15s;
    border: none;
    background: none;
    cursor: pointer;
  }
  .toolbar-btn:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  /* ─── Columns ─────────────────────────────────── */
  .columns {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    flex: 1;
    min-height: 0;
    padding-bottom: 1rem;
  }

  .column {
    flex: 0 0 19rem;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    overflow: hidden;
  }

  .column-header {
    padding: 0.75rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .column-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .column-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .column-dot--slate   { background: #94a3b8; }
  .column-dot--amber   { background: #fbbf24; }
  .column-dot--purple  { background: #a78bfa; }
  .column-dot--emerald { background: #34d399; }

  .column-count {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    padding: 0.0625rem 0.4375rem;
    border-radius: 9999px;
    margin-left: auto;
  }

  .column-cards {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  /* ─── Card ─────────────────────────────────────── */
  .card {
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    flex-shrink: 0;
  }

  .card:hover {
    border-color: rgba(129, 140, 248, 0.3);
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.08);
  }

  .card--done {
    opacity: 0.55;
  }
  .card--done:hover {
    opacity: 0.75;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.375rem;
  }

  .card-tag {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
  .card-tag--feature { background: rgba(99,102,241,0.12);  color: #818cf8; }
  .card-tag--bug     { background: rgba(248,113,113,0.12);  color: #f87171; }
  .card-tag--chore   { background: rgba(148,163,184,0.12);  color: #94a3b8; }

  .card-priority {
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.0625rem 0.3125rem;
    border-radius: 0.25rem;
    margin-left: auto;
  }
  .card-priority--low  { background: rgba(148,163,184,0.1);  color: #94a3b8; }
  .card-priority--med  { background: rgba(251,191,36,0.12);  color: #fbbf24; }
  .card-priority--high { background: rgba(248,113,113,0.12); color: #f87171; }

  .card-title {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.625rem;
  }

  .card-id {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
  }

  .card-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.375rem; height: 1.375rem;
    border-radius: 50%;
    background: rgba(99,102,241,0.15);
    color: #818cf8;
    font-size: 0.5rem;
    font-weight: 700;
  }

  .card-bottom {
    margin-top: 0.5rem;
  }

  .card-bottom .card-id {
    display: block;
  }
</style>
