---
import AppLayout from '../../../layouts/AppLayout.astro';
---

<AppLayout title="Organization Settings" pageTitle="Organization Settings">
  <div class="mx-auto max-w-4xl p-6" x-data="orgSettings()" x-init="init()">
    <h1 class="mb-6 text-2xl font-bold text-[var(--color-text)]">Organization Settings</h1>

    <!-- Members Section -->
    <section class="mb-8">
      <h2 class="mb-4 text-lg font-semibold text-[var(--color-text)]">Members</h2>

      <div x-show="loading" class="text-[var(--color-text-secondary)]">Loading members...</div>

      <div x-show="!loading && members.length === 0" class="text-[var(--color-text-secondary)]">
        No members found.
      </div>

      <div x-show="!loading && members.length > 0" class="space-y-2">
        <template x-for="member in members" :key="member.userId">
          <div class="flex items-center justify-between rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
            <div class="flex items-center gap-3">
              <img
                :src="member.avatarUrl || 'https://www.gravatar.com/avatar/?d=mp'"
                :alt="member.displayName"
                class="h-10 w-10 rounded-full bg-[var(--color-border)]"
              />
              <div>
                <p class="font-medium text-[var(--color-text)]" x-text="member.displayName"></p>
                <p class="text-sm text-[var(--color-text-secondary)]" x-text="member.email"></p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span
                class="rounded-full px-2 py-1 text-xs font-medium"
                :class="member.role === 'Owner' ? 'bg-brand-100 text-brand-700' : 'bg-gray-100 text-gray-700'"
                x-text="member.role"
              ></span>
              <button
                x-show="isOwner && member.role !== 'Owner'"
                @click="removeMember(member.userId)"
                class="rounded px-3 py-1 text-sm text-red-600 hover:bg-red-50"
              >
                Remove
              </button>
            </div>
          </div>
        </template>
      </div>
    </section>

    <!-- Invitations Section -->
    <section class="mb-8">
      <h2 class="mb-4 text-lg font-semibold text-[var(--color-text)]">Invite Members</h2>

      <form @submit.prevent="sendInvitation()" class="flex gap-2">
        <input
          type="email"
          x-model="inviteEmail"
          placeholder="Email address"
          required
          class="flex-1 rounded border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)]"
        />
        <select
          x-model="inviteRole"
          class="rounded border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)]"
        >
          <option value="Member">Member</option>
          <option value="Owner">Owner</option>
        </select>
        <button
          type="submit"
          class="rounded bg-brand-600 px-4 py-2 text-sm text-white hover:bg-brand-700"
        >
          Send Invite
        </button>
      </form>

      <p x-show="inviteError" class="mt-2 text-sm text-red-600" x-text="inviteError"></p>
      <p x-show="inviteSuccess" class="mt-2 text-sm text-green-600">Invitation sent successfully!</p>
    </section>
  </div>
</AppLayout>

<script>
  function orgSettings() {
    return {
      loading: true,
      members: [] as any[],
      isOwner: false,
      inviteEmail: '',
      inviteRole: 'Member',
      inviteError: '',
      inviteSuccess: false,
      orgId: '' as string,

      async init() {
        // Get orgId from URL path
        const pathParts = window.location.pathname.split('/');
        this.orgId = pathParts[pathParts.length - 2] || '';

        await this.loadMembers();
      },

      async loadMembers() {
        if (!this.orgId) return;

        try {
          const response = await fetch(`/api/orgs/${this.orgId}/members`);
          if (response.ok) {
            this.members = await response.json();
            // Check if current user is owner
            const currentUserId = this.getCurrentUserId();
            const currentMember = this.members.find((m: any) => m.userId === currentUserId);
            this.isOwner = currentMember?.role === 'Owner';
          }
        } catch (error) {
          console.error('Failed to load members:', error);
        } finally {
          this.loading = false;
        }
      },

      getCurrentUserId(): string {
        // Get from localStorage or Astro.locals
        return localStorage.getItem('userId') || '';
      },

      async removeMember(userId: string) {
        if (!confirm('Are you sure you want to remove this member?')) return;

        try {
          const response = await fetch(`/api/orgs/${this.orgId}/members/${userId}?requesterUserId=${this.getCurrentUserId()}`, {
            method: 'DELETE',
          });

          if (response.ok) {
            this.members = this.members.filter((m: any) => m.userId !== userId);
          } else {
            alert('Failed to remove member');
          }
        } catch (error) {
          console.error('Failed to remove member:', error);
          alert('Failed to remove member');
        }
      },

      async sendInvitation() {
        this.inviteError = '';
        this.inviteSuccess = false;

        try {
          const response = await fetch(`/api/orgs/${this.orgId}/invitations`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: this.inviteEmail, role: this.inviteRole }),
          });

          if (response.ok) {
            this.inviteSuccess = true;
            this.inviteEmail = '';
            this.inviteRole = 'Member';
            setTimeout(() => { this.inviteSuccess = false; }, 3000);
          } else {
            this.inviteError = 'Failed to send invitation';
          }
        } catch (error) {
          console.error('Failed to send invitation:', error);
          this.inviteError = 'Failed to send invitation';
        }
      }
    };
  }
</script>