---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';

export function getStaticPaths() {
  return [{ params: { orgId: 'placeholder' } }];
}

const { orgId } = Astro.params;
---

<AppLayout title="Settings" pageTitle="Settings">
  <EmptyState
    title="Organization Settings"
    description={`Settings for organization ${orgId}. This page will be built in a future task.`}
    icon="inbox"
  />
</AppLayout>
