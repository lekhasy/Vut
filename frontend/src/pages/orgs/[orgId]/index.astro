---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';

export function getStaticPaths() {
  // Placeholder — real org IDs come from API at runtime via client-side routing
  return [{ params: { orgId: 'placeholder' } }];
}

const { orgId } = Astro.params;
---

<AppLayout title="Organization" pageTitle="Organization Dashboard">
  <EmptyState
    title="Organization Dashboard"
    description={`Viewing organization ${orgId}. Content will appear here when backend integration is complete.`}
    icon="inbox"
  />
</AppLayout>
