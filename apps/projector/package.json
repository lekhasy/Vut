{
  "name": "@velucid/projector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun build src/main.ts --target=bun --outdir=dist --external=@kurrent/kurrentdb-client --external=@openfga/sdk --external=drizzle-orm --external=pg",
    "serve": "bun run src/main.ts",
    "start": "bun run dist/main.js",
    "test": "bun test"
  },
  "dependencies": {
    "@kurrent/kurrentdb-client": "^1.3.0",
    "@openfga/sdk": "^0.9.6",
    "@velucid/events": "workspace:*",
    "@velucid/kurrent-client": "workspace:*",
    "@velucid/projection": "workspace:*",
    "@velucid/read-model": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "typescript": "5.8.3"
  }
}
