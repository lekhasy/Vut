---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Verify Email">
  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm text-center">
    <div class="mb-4">
      <svg class="mx-auto h-12 w-12 text-brand-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>
    <h1 class="mb-2 text-xl font-semibold text-[var(--color-text)]">
      Verify your email
    </h1>
    <p class="mb-6 text-sm text-[var(--color-text-secondary)]">
      We need to verify your email address before you can continue.
      Check your inbox for a verification link.
    </p>
    <p class="text-xs text-[var(--color-text-secondary)]">
      Didn't receive an email? Check your spam folder or try signing in again.
    </p>
  </div>
</AuthLayout>
