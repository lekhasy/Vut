    <!-- GSAP Animations -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // --- Hero entrance ---
      const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      heroTl
        .fromTo('#hero-badge', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.5 }, 0.15)
        .fromTo('#hero-title', { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.7 }, 0.3)
        .fromTo('#hero-desc', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, 0.65)
        .fromTo('#hero-cta', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.5 }, 0.9)
        .fromTo('#hero-card', { opacity: 0, y: 32, scale: 0.98 }, { opacity: 1, y: 0, scale: 1, duration: 0.7 }, 1.1);

      // --- Slogan strikethrough on "Their" ---
      // "Your" chip pulses with a subtle glow, then "Their" gets struck through
      heroTl.to('.slogan-your', {
        boxShadow: '0 4px 32px rgba(79, 70, 229, 0.35)',
        duration: 0.6,
        ease: 'power2.out',
      }, 1.4);

      heroTl.add(() => {
        document.getElementById('slogan-their')?.classList.add('struck');
      }, 1.7);

      // Animate the strikethrough line in
      heroTl.fromTo(
        '#slogan-their::after',
        { scaleX: 0 },
        { scaleX: 1, duration: 0.4 },
        1.7
      );

      // Use a real element approach for the strikethrough animation
      heroTl.to('#slogan-their', {
        onStart: () => {
          const el = document.getElementById('slogan-their');
          if (!el) return;
          el.classList.add('struck');
          const line = el.querySelector('.strike-line') as HTMLElement | null;
          if (line) {
            gsap.fromTo(line, { scaleX: 0 }, { scaleX: 1, duration: 0.4, ease: 'power2.out' });
          }
        },
        duration: 0.01,
      }, 1.7);

      // --- Scroll-triggered sections ---
      gsap.utils.toArray<HTMLElement>('.section-heading').forEach((el) => {
        gsap.fromTo(el,
          { opacity: 0, y: 24 },
          {
            opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
          }
        );
      });

      // Feature cards
      gsap.utils.toArray<HTMLElement>('.feature-card').forEach((card, i) => {
        gsap.fromTo(card,
          { opacity: 0, y: 32 },
          {
            opacity: 1, y: 0, duration: 0.5, delay: i * 0.12, ease: 'power2.out',
            scrollTrigger: { trigger: card, start: 'top 88%', toggleActions: 'play none none none' },
          }
        );
      });

      // Steps
      gsap.utils.toArray<HTMLElement>('.step-item').forEach((step, i) => {
        gsap.fromTo(step,
          { opacity: 0, y: 32 },
          {
            opacity: 1, y: 0, duration: 0.6, delay: i * 0.15, ease: 'power2.out',
            scrollTrigger: { trigger: step, start: 'top 88%', toggleActions: 'play none none none' },
          }
        );
      });

      // CTA
      const ctaEl = document.querySelector('.cta-section');
      if (ctaEl) {
        gsap.fromTo(ctaEl,
          { opacity: 0, scale: 0.96 },
          {
            opacity: 1, scale: 1, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: ctaEl, start: 'top 85%', toggleActions: 'play none none none' },
          }
        );
      }

      // --- S-curve chart animation ---
      const cfdWrapper = document.getElementById('cfd-wrapper');
      if (cfdWrapper) {
        gsap.fromTo(cfdWrapper,
          { opacity: 0, y: 32 },
          {
            opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: {
              trigger: cfdWrapper,
              start: 'top 85%',
              toggleActions: 'play none none none',
              onEnter: () => {
                const tl = gsap.timeline({ delay: 0.3 });

                // 1. Fade in stat cards
                tl.fromTo('#scurve-stats',
                  { opacity: 0, y: 12 },
                  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, 0);

                // 2. Fade in histogram bars
                tl.to('#scurve-histogram', { opacity: 1, duration: 0.6, ease: 'power2.out' }, 0.3);

                // 3. Draw the S-curve line
                const curveLine = document.getElementById('scurve-line');
                if (curveLine) {
                  const len = (curveLine as unknown as SVGGeometryElement).getTotalLength?.() || 700;
                  gsap.set(curveLine, { strokeDasharray: len, strokeDashoffset: len });
                  tl.to(curveLine, { opacity: 1, duration: 0.01 }, 0.6);
                  tl.to(curveLine, { strokeDashoffset: 0, duration: 1.2, ease: 'power2.inOut' }, 0.6);
                }

                // 4. Fade in amber commitment window fill
                tl.to('#scurve-amber-fill', { opacity: 1, duration: 0.5, ease: 'power2.out' }, 1.5);

                // 5. Show amber threshold line
                tl.to('#scurve-threshold', { opacity: 1, duration: 0.4, ease: 'power2.out' }, 1.7);

                // 6. Show horizontal crosshair
                tl.to('#scurve-crosshair', { opacity: 1, duration: 0.4, ease: 'power2.out' }, 1.8);

                // 7. Pop in the intersection dot
                tl.fromTo('#scurve-dot',
                  { opacity: 0, scale: 0, transformOrigin: 'center center' },
                  { opacity: 1, scale: 1, duration: 0.3, ease: 'back.out(2)' }, 2.0);

                // 8. Show percentile markers
                tl.to('#scurve-p50', { opacity: 1, duration: 0.3 }, 2.1);
                tl.to('#scurve-p70-label', { opacity: 1, duration: 0.3 }, 2.2);
                tl.to('#scurve-p95', { opacity: 1, duration: 0.3 }, 2.3);

                // 9. Reveal the callout
                tl.fromTo('#scurve-callout',
                  { opacity: 0, y: 6 },
                  { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, 2.5);
              },
            },
          }
        );
      }

    </script>
