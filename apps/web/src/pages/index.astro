---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Velucid — Your first release. Their first refinement. Project management purpose-built for modern software development." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>Velucid — Your First Release. Their First Refinement.</title>
    <style>
      /* Landing page scoped styles — keep out of global.css */
      .landing-body {
        --lp-bg: #fafbfc;
        --lp-surface: #ffffff;
        --lp-text: #1a1a2e;
        --lp-text-secondary: #64748b;
        --lp-border: #e2e8f0;
        --lp-accent: #4f46e5;
        --lp-accent-light: #eef2ff;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--lp-bg);
        color: var(--lp-text);
      }

      /* Slogan: "Your" chip */
      .slogan-your {
        display: inline-flex;
        align-items: center;
        gap: 0.35em;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        padding: 0.08em 0.4em;
        border-radius: 0.25em;
        box-shadow: 0 4px 24px rgba(79, 70, 229, 0.25);
      }

      /* Slogan: "Their" chip */
      .slogan-their {
        position: relative;
        display: inline-block;
        color: #94a3b8;
      }
      .slogan-their::after {
        content: '';
        position: absolute;
        left: -2%;
        right: -2%;
        top: 52%;
        height: 3px;
        background: #e11d48;
        border-radius: 2px;
        transform: rotate(-1deg);
        opacity: 0;
      }
      .slogan-their.struck::after {
        opacity: 0.7;
      }

      /* Subtle dot grid */
      .dot-grid {
        background-image: radial-gradient(circle, #cbd5e1 0.7px, transparent 0.7px);
        background-size: 28px 28px;
      }

      /* Gradient mesh blob */
      .mesh-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.35;
        pointer-events: none;
      }
    </style>
  </head>
  <body class="landing-body min-h-screen overflow-x-hidden">

    <!-- Navigation -->
    <nav id="nav" class="fixed top-0 inset-x-0 z-50 border-b border-[var(--lp-border)] bg-[var(--lp-surface)]/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl flex items-center justify-between px-5 sm:px-8 h-16">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="Velucid home">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-xs shadow-md">
            Vc
          </span>
          <span class="text-lg font-bold text-[var(--lp-text)]">Velucid</span>
        </a>
        <a
          href="/auth/login"
          class="inline-flex items-center justify-center rounded-lg bg-[var(--lp-accent)] px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 shadow-sm hover:shadow-md hover:-translate-y-px"
        >
          Get Started Free
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative pt-28 pb-20 sm:pt-40 sm:pb-28 px-5 sm:px-8 overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute inset-0 dot-grid opacity-40 pointer-events-none" aria-hidden="true"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-brand-300 top-[-100px] right-[-100px]" aria-hidden="true"></div>
      <div class="mesh-blob w-[400px] h-[400px] bg-purple-300 bottom-[-80px] left-[-80px]" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl text-center">
        <!-- Badge -->
        <div id="hero-badge" class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-[var(--lp-accent-light)] px-4 py-1.5 text-sm font-medium text-brand-700 mb-10 opacity-0">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
          </span>
          Purpose-built for modern software teams · Free to start
        </div>

        <!-- Slogan -->
        <h1 id="hero-title" class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.15] opacity-0">
          <span id="slogan-line1" class="block">
            <span class="slogan-your">Your</span> first release.
          </span>
          <span id="slogan-line2" class="block mt-3 sm:mt-4">
            <span class="slogan-their" id="slogan-their">Their</span>
            <span class="text-[#94a3b8]"> first refinement.</span>
          </span>
        </h1>

        <p id="hero-desc" class="mt-8 text-lg sm:text-xl text-[var(--lp-text-secondary)] max-w-2xl mx-auto leading-relaxed opacity-0">
          Velucid gives fast-moving teams a board in minutes, and honest probability forecasts — not a single date that's probably a lie.
        </p>

        <div id="hero-cta" class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0">
          <a
            href="/auth/login"
            class="group inline-flex items-center justify-center rounded-xl bg-[var(--lp-accent)] px-7 py-3.5 text-base font-semibold text-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 shadow-lg shadow-brand-500/20 hover:shadow-xl hover:shadow-brand-500/30 hover:-translate-y-0.5"
          >
            Get Started Free
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="#forecast"
            class="inline-flex items-center justify-center rounded-xl border border-[var(--lp-border)] bg-white px-7 py-3.5 text-base font-semibold text-[var(--lp-text)] hover:border-slate-300 hover:shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500"
          >
            See How It Works
          </a>
        </div>

        <!-- Dashboard mockup card -->
        <div id="hero-card" class="mt-16 sm:mt-20 mx-auto max-w-2xl opacity-0">
          <div class="rounded-2xl border border-[var(--lp-border)] bg-white shadow-xl shadow-slate-200/60 overflow-hidden">
            <!-- Window chrome -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--lp-border)] bg-slate-50/80">
              <span class="h-3 w-3 rounded-full bg-red-400/70"></span>
              <span class="h-3 w-3 rounded-full bg-amber-400/70"></span>
              <span class="h-3 w-3 rounded-full bg-emerald-400/70"></span>
              <span class="ml-3 text-xs text-slate-400 font-medium">Velucid — Project overview</span>
            </div>
            <!-- Content -->
            <div class="p-5 sm:p-6">
              <!-- Mini kanban -->
              <div class="grid grid-cols-3 gap-3 text-left">
                <div>
                  <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Backlog</div>
                  <div class="space-y-2">
                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-2.5 text-xs text-slate-600">Auth flow redesign</div>
                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-2.5 text-xs text-slate-600">API rate limiting</div>
                    <div class="rounded-lg border border-brand-200 bg-brand-50 p-2.5 text-xs text-brand-700 font-medium">+ 10 more</div>
                  </div>
                </div>
                <div>
                  <div class="text-xs font-semibold text-amber-500 uppercase tracking-wider mb-2">In Progress</div>
                  <div class="space-y-2">
                    <div class="rounded-lg border border-amber-200 bg-amber-50 p-2.5 text-xs text-amber-700">Dashboard charts</div>
                    <div class="rounded-lg border border-amber-200 bg-amber-50 p-2.5 text-xs text-amber-700">Team invites</div>
                  </div>
                </div>
                <div>
                  <div class="text-xs font-semibold text-emerald-500 uppercase tracking-wider mb-2">Done</div>
                  <div class="space-y-2">
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-2.5 text-xs text-emerald-700">Onboarding flow</div>
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-2.5 text-xs text-emerald-700">SSO login</div>
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-2.5 text-xs text-emerald-700">Kanban DnD</div>
                  </div>
                </div>
              </div>
              <!-- Probability forecast bar -->
              <div class="mt-5 grid grid-cols-3 gap-2">
                <div class="rounded-lg bg-slate-50 border border-slate-200 px-3 py-2.5 text-center">
                  <div class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">50/50 forecast</div>
                  <div class="text-sm font-bold text-slate-600 mt-0.5">Jun 8</div>
                </div>
                <div class="rounded-lg bg-brand-50 border border-brand-200 px-3 py-2.5 text-center ring-1 ring-brand-300">
                  <div class="text-[10px] font-medium text-brand-500 uppercase tracking-wider">Planning date · 70%</div>
                  <div class="text-sm font-bold text-brand-700 mt-0.5">Jun 14</div>
                </div>
                <div class="rounded-lg bg-slate-50 border border-slate-200 px-3 py-2.5 text-center">
                  <div class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">95% likely by</div>
                  <div class="text-sm font-bold text-slate-600 mt-0.5">Jun 28</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="relative z-10 py-20 sm:py-28 px-5 sm:px-8 bg-white border-y border-[var(--lp-border)]">
      <div class="mx-auto max-w-6xl">
        <div class="text-center mb-16 sm:mb-20">
          <h2 class="section-heading text-3xl sm:text-4xl font-bold text-[var(--lp-text)] opacity-0">Less overhead. More control.</h2>
          <p class="section-heading mt-4 text-[var(--lp-text-secondary)] text-lg max-w-2xl mx-auto opacity-0">
            Built around how software teams actually work — not how a generic tool thinks you should.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Card 1 -->
          <div class="feature-card rounded-2xl border border-[var(--lp-border)] bg-white p-7 hover:shadow-lg hover:shadow-slate-200/60 hover:border-brand-200 transition-all duration-300 opacity-0 group">
            <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-600 ring-1 ring-brand-100 group-hover:bg-brand-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--lp-text)]">Set up in minutes</h3>
            <p class="mt-2 text-sm text-[var(--lp-text-secondary)] leading-relaxed">
              No week-long onboarding. Create a board, invite your team, and start tracking features, bugs, and releases — all before your first coffee gets cold.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="feature-card rounded-2xl border border-[var(--lp-border)] bg-white p-7 hover:shadow-lg hover:shadow-slate-200/60 hover:border-purple-200 transition-all duration-300 opacity-0 group">
            <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-purple-50 text-purple-600 ring-1 ring-purple-100 group-hover:bg-purple-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--lp-text)]">See the odds, not a guess</h3>
            <p class="mt-2 text-sm text-[var(--lp-text-secondary)] leading-relaxed">
              Velucid watches how work flows through your pipeline and builds a probability forecast — not a single date. You choose the confidence level. No forecasting meetings, no false precision.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="feature-card rounded-2xl border border-[var(--lp-border)] bg-white p-7 hover:shadow-lg hover:shadow-slate-200/60 hover:border-emerald-200 transition-all duration-300 opacity-0 group">
            <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 ring-1 ring-emerald-100 group-hover:bg-emerald-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--lp-text)]">Hours back, every single week</h3>
            <p class="mt-2 text-sm text-[var(--lp-text-secondary)] leading-relaxed">
              Spend your time the way you choose. Velucid works around your process — giving you hours back for what matters most.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Forecast S-curve showcase -->
    <section id="forecast" class="relative z-10 py-20 sm:py-28 px-5 sm:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-12 sm:mb-16">
          <h2 class="section-heading text-3xl sm:text-4xl font-bold text-[var(--lp-text)] opacity-0">Accurate forecast numbers, not a best guess.</h2>
          <p class="section-heading mt-4 text-[var(--lp-text-secondary)] text-lg max-w-2xl mx-auto opacity-0">
            A single date pretends the future is certain. Velucid runs thousands of simulations and shows you a probability curve — where the forecast narrows as your team delivers consistently.
          </p>
        </div>

        <div id="cfd-wrapper" class="rounded-2xl border border-[var(--lp-border)] bg-white shadow-xl shadow-slate-200/60 overflow-hidden opacity-0">
          <!-- Window chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--lp-border)] bg-slate-50/80">
            <span class="h-3 w-3 rounded-full bg-red-400/70"></span>
            <span class="h-3 w-3 rounded-full bg-amber-400/70"></span>
            <span class="h-3 w-3 rounded-full bg-emerald-400/70"></span>
            <span class="ml-3 text-xs text-slate-400 font-medium">Velucid — Forecast</span>
          </div>

          <div class="p-4 sm:p-6 lg:p-8">
            <!-- Stat cards -->
            <div id="scurve-stats" class="flex flex-wrap items-end gap-3 mb-5 opacity-0">
              <div class="flex-1 min-w-[90px] rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-center">
                <div class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">50/50 forecast</div>
                <div class="text-sm font-bold text-slate-600 mt-0.5">Jun 8</div>
              </div>
              <div class="flex-1 min-w-[90px] rounded-lg border-2 border-amber-300 bg-amber-50 px-3 py-2.5 text-center shadow-sm">
                <div class="text-[10px] font-medium text-amber-600 uppercase tracking-wider">Planning date · 70%</div>
                <div class="text-sm font-bold text-amber-700 mt-0.5">Jun 14</div>
              </div>
              <div class="flex-1 min-w-[90px] rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-center">
                <div class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">95% likely by</div>
                <div class="text-sm font-bold text-slate-600 mt-0.5">Jun 28</div>
              </div>
              <div class="flex-1 min-w-[110px] rounded-lg border border-slate-200 bg-white px-3 py-2">
                <div class="text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5">Confidence</div>
                <div class="relative h-1.5 bg-slate-200 rounded-full">
                  <div class="absolute left-0 top-0 h-1.5 bg-amber-400 rounded-full" style="width:53%"></div>
                  <div class="absolute top-1/2 -translate-y-1/2 h-3 w-3 rounded-full bg-amber-500 border-2 border-white shadow-sm" style="left:calc(53% - 6px)"></div>
                </div>
                <div class="text-right text-[10px] text-amber-600 font-semibold mt-1">70%</div>
              </div>
            </div>

            <!-- Legend -->
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-4 text-xs font-medium">
              <span class="flex items-center gap-1.5"><span class="h-0.5 w-5 rounded bg-[#378ADD]"></span><span class="text-slate-500">Probability of completion</span></span>
              <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-[#378ADD]/20"></span><span class="text-slate-500">Simulation density</span></span>
              <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-amber-400/30"></span><span class="text-slate-500">Commitment window</span></span>
              <span class="flex items-center gap-1.5"><span class="h-0.5 w-5 rounded bg-amber-500"></span><span class="text-slate-500">Selected confidence</span></span>
            </div>

            <!-- S-Curve Forecast Chart -->
            <svg id="scurve-chart" viewBox="0 0 760 340" class="w-full h-auto" role="img" aria-label="Probability S-curve showing the cumulative likelihood of project completion over time. The amber region highlights the commitment window up to the selected 70 percent confidence date of June 14. No single date is shown as the answer — the curve communicates the full probability distribution.">
              <defs>
                <linearGradient id="grad-amber-fill" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#EF9F27" stop-opacity="0.22" />
                  <stop offset="100%" stop-color="#EF9F27" stop-opacity="0.06" />
                </linearGradient>
              </defs>

              <!--
                S-Curve (CDF) — Primary forecast view
                Chart area: x=80..680, y=40..290 (W=600, H=250)
                X-axis: calendar dates (May 25 – Jul 3)
                Left Y-axis: cumulative probability 0-100%

                Key percentiles matching stat cards:
                  p50: Jun 8  → x≈295, y=165
                  p70: Jun 14 → x≈388, y=115
                  p95: Jun 28 → x≈603, y=52
              -->

              <!-- Grid lines at 20% intervals -->
              <g stroke="#e2e8f0" stroke-width="0.5">
                <line x1="80" y1="90" x2="680" y2="90" />
                <line x1="80" y1="140" x2="680" y2="140" />
                <line x1="80" y1="190" x2="680" y2="190" />
                <line x1="80" y1="240" x2="680" y2="240" />
              </g>

              <!-- Left Y-axis labels (cumulative probability) -->
              <g fill="#94a3b8" font-size="11" text-anchor="end">
                <text x="72" y="44">100%</text>
                <text x="72" y="94">80%</text>
                <text x="72" y="144">60%</text>
                <text x="72" y="194">40%</text>
                <text x="72" y="244">20%</text>
                <text x="72" y="294">0%</text>
              </g>

              <!-- Right Y-axis label (density) -->
              <text x="738" y="172" fill="#94a3b8" font-size="9" text-anchor="middle" transform="rotate(90,738,172)">Density</text>

              <!-- X-axis date labels (positioned to avoid overlap with percentile markers) -->
              <g fill="#94a3b8" font-size="10" text-anchor="middle">
                <text x="126" y="310">May 28</text>
                <text x="234" y="310">Jun 4</text>
                <text x="341" y="310">Jun 11</text>
                <text x="449" y="310">Jun 18</text>
                <text x="557" y="310">Jun 25</text>
              </g>

              <!-- Axes -->
              <line x1="80" y1="290" x2="700" y2="290" stroke="#cbd5e1" stroke-width="1" />
              <line x1="80" y1="36" x2="80" y2="290" stroke="#cbd5e1" stroke-width="1" />
              <line x1="680" y1="36" x2="680" y2="290" stroke="#cbd5e1" stroke-width="0.5" stroke-dasharray="2,3" />
              <text x="22" y="168" fill="#94a3b8" font-size="10" text-anchor="middle" transform="rotate(-90,22,168)">Probability</text>

              <!-- Histogram bars (probability density behind the S-curve) -->
              <g id="scurve-histogram" opacity="0">
                <rect x="106" y="272" width="40" height="18" rx="2" fill="#378ADD" opacity="0.12" />
                <rect x="155" y="240" width="40" height="50" rx="2" fill="#378ADD" opacity="0.12" />
                <rect x="204" y="198" width="40" height="92" rx="2" fill="#378ADD" opacity="0.15" />
                <rect x="253" y="185" width="40" height="105" rx="2" fill="#378ADD" opacity="0.18" />
                <rect x="302" y="210" width="40" height="80" rx="2" fill="#378ADD" opacity="0.15" />
                <rect x="351" y="238" width="40" height="52" rx="2" fill="#378ADD" opacity="0.12" />
                <rect x="400" y="255" width="40" height="35" rx="2" fill="#378ADD" opacity="0.1" />
                <rect x="449" y="267" width="40" height="23" rx="2" fill="#378ADD" opacity="0.08" />
                <rect x="498" y="275" width="40" height="15" rx="2" fill="#378ADD" opacity="0.07" />
                <rect x="547" y="279" width="40" height="11" rx="2" fill="#378ADD" opacity="0.06" />
                <rect x="596" y="283" width="40" height="7" rx="2" fill="#378ADD" opacity="0.05" />
              </g>

              <!-- Amber fill under S-curve left of p70 threshold (commitment window) -->
              <path id="scurve-amber-fill" fill="url(#grad-amber-fill)" opacity="0"
                d="M80,290 L95,290 L110,289 L130,287 L150,282 L170,272 L188,262 L205,250 L220,238 L235,225
                   L250,212 L265,198 L280,185 L295,165 L310,150 L325,140 L340,133 L355,127 L370,120 L388,115
                   L388,290 Z" />

              <!-- S-curve line (blue) -->
              <polyline id="scurve-line" fill="none" stroke="#378ADD" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0"
