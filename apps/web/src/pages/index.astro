---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Velucid gives your team probability-based delivery forecasts — continuously updated from real throughput data. Know when it ships."
    />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>Velucid — Know when it ships.</title>
    <style>
      /* ── Industrial UI typography per design-artifacts/D-Design-System/DesignGuideline.html
            Barlow Condensed · weights 400/600/700 only · tracking inversion · caps discipline
            Light mode: bg #f0f0ee (inverted from dark mode text-primary) ── */
      :root {
        --bg: #ffffff;
        --bg-surface: #f5f5f3;
        --bg-subtle: #ebebea;
        --border: rgba(0, 0, 0, 0.08);
        --border-strong: rgba(0, 0, 0, 0.16);
        --text-primary: #0a0a0a;
        --text-secondary: #444442;
        --text-muted: #888884;
        --mono: 'Share Tech Mono', monospace;
        --sans: 'Barlow Condensed', sans-serif;
      }

      .landing-body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--text-primary);
        -webkit-font-smoothing: antialiased;
        font-size: 0.9375rem;
        line-height: 1.5;
      }

      /* Hairline borders (0.5px) */
      .hairline { border-color: var(--border); }
      .hairline-strong { border-color: var(--border-strong); }

      /* ── Type scale (R-01, R-02, R-03, R-04) ── */

      .t-hero {
        font-size: clamp(2.75rem, 7vw, 5rem);
        font-weight: 700;
        letter-spacing: 0.02em;
        line-height: 0.93;
        text-transform: uppercase;
        color: var(--text-primary);
      }

      .t-h2 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        letter-spacing: 0.03em;
        line-height: 1.0;
        text-transform: uppercase;
        color: var(--text-primary);
      }

      .t-h3 {
        font-size: 1.625rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.05;
        text-transform: uppercase;
        color: var(--text-primary);
      }

      /* Labels use mono for industrial metadata feel (R-04 weight 600) */
      .t-label {
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 400;
        letter-spacing: 0.04em;
        line-height: 1;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .t-eyebrow {
        font-family: var(--mono);
        font-size: 0.6875rem;
        font-weight: 400;
        letter-spacing: 0.06em;
        line-height: 1;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      /* Top bar: a notch larger than the default label/eyebrow so
         the brand + CTA read at a glance, but stays small enough
         to feel like a header rather than a nav. Footer/columns
         that also use .t-label stay at the base size. */
      header.top-bar .t-label {
        font-size: 0.875rem;
      }
      header.top-bar .t-eyebrow {
        font-size: 0.75rem;
      }

      .t-subhead {
        font-size: 1.125rem;
        font-weight: 400;
        letter-spacing: 0.01em;
        line-height: 1.6;
        color: var(--text-secondary);
      }

      .t-body {
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0.01em;
        line-height: 1.5;
        color: var(--text-secondary);
      }

      /* ── Typographic reveal — left-to-right character sweep ──
         Applied to the 5 named elements only. Falls back to
         final state when scroll-driven animations unsupported. */
      @keyframes reveal {
        from { clip-path: inset(0 100% 0 0); }
        to   { clip-path: inset(0 0 0 0); }
      }
      .reveal {
        clip-path: inset(0 0 0 0);
      }
      @supports (animation-timeline: view()) {
        .reveal {
          animation: reveal linear both;
          animation-timeline: view();
          animation-range: entry 0% entry 60%;
        }
      }

      /* ── Plain rectangular CTA (R-04: weight 600, tracking 0.12em) ── */
      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 22px;
        font-family: var(--sans);
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        line-height: 1;
        text-transform: uppercase;
        border-radius: 0;
        transition: background-color 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out;
        text-decoration: none;
        cursor: pointer;
      }
      .cta-primary {
        background: var(--text-primary);
        color: var(--bg);
        border: 1px solid var(--text-primary);
      }
      .cta-primary:hover {
        background: #2a2a2a;
        border-color: #2a2a2a;
      }
      .cta-secondary {
        background: transparent;
        color: var(--text-primary);
        border: 1px solid var(--border-strong);
      }
      .cta-secondary:hover {
        background: var(--text-primary);
        color: var(--bg);
        border-color: var(--text-primary);
      }

      /* ── Pills (region, social) ── */
      .pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-secondary);
        background: transparent;
        border: 0.5px solid var(--border-strong);
        border-radius: 999px;
        text-decoration: none;
        transition: background-color 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out;
      }
      a.pill:hover {
        background: var(--text-primary);
        color: var(--bg);
        border-color: var(--text-primary);
      }

      /* ── Stat block (per design system demo-stats pattern) ── */
      .stat-label {
        font-family: var(--mono);
        font-size: 0.6875rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        line-height: 1;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      .stat-val {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: 0.01em;
        line-height: 1;
        color: var(--text-primary);
      }
      .stat-unit {
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--text-secondary);
        margin-left: 4px;
      }

      /* ── Surface sections ── */
      .section-surface {
        background: var(--bg-surface);
      }

      /* ── Stat grid bordered (design guide demo-stats pattern) ── */
      .stat-grid-cell {
        position: relative;
        padding: 28px 32px;
        border-bottom: 0.5px solid var(--border-strong);
        background: transparent;
        transition: background 200ms ease-out;
        overflow: hidden;
      }
      /* Top accent bar sweeps in from the left on hover */
      .stat-grid-cell::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: var(--text-primary);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 220ms ease-out;
      }
      .stat-grid-cell:hover {
        background: #ffffff;
      }
      .stat-grid-cell:hover::before {
        transform: scaleX(1);
      }
      .stat-grid-cell:hover .stat-label {
        color: var(--text-secondary);
      }
      /* Hint line fades up on hover */
      .stat-hint {
        font-family: var(--mono);
        font-size: 0.6875rem;
        color: var(--text-muted);
        margin-top: 10px;
        opacity: 0;
        transform: translateY(5px);
        transition: opacity 220ms ease-out 60ms, transform 220ms ease-out 60ms;
      }
      .stat-grid-cell:hover .stat-hint {
        opacity: 1;
        transform: translateY(0);
      }
      @media (min-width: 640px) {
        .stat-grid-cell { border-bottom: none; border-right: 0.5px solid var(--border-strong); }
        .stat-grid-cell:last-child { border-right: none; }
      }

      /* Footer link color */
      .footer-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 150ms ease-out;
      }
      .footer-link:hover { color: var(--text-primary); }

      /* ── Animated text reveal (gradient sweep) ──
         No width measurement. The text shape is filled by a
         solid background that grows from 0% to 100% in N steps.
         The animation is driven from JS via the Web Animations
         API (see <script> at the end of <body>) — CSS @keyframes
         is intentionally avoided because var()-based step counts
         and the parent .js class are awkward in scoped styles.
         :global(.js) keeps the parent selector unscoped so it
         matches <html>, which has no data-astro-cid attribute. */
      .tw {
        display: inline-block;
      }
      :global(.js) .tw {
        color: transparent;
        background-image: linear-gradient(
          to right,
          var(--text-primary) 0%,
          var(--text-primary) 100%
        );
        background-size: 0% 100%;
        background-repeat: no-repeat;
        background-position: 0% 0%;
        -webkit-background-clip: text;
        background-clip: text;
      }
      @media (prefers-reduced-motion: reduce) {
        :global(.js) .tw {
          color: currentColor;
          background-image: none;
          -webkit-background-clip: border-box;
          background-clip: border-box;
        }
      }
    </style>
  </head>
  <body class="landing-body min-h-screen overflow-x-hidden">

    <!-- ── TOP BAR ── -->
    <header class="border-b hairline top-bar">
      <div class="mx-auto max-w-6xl flex items-center justify-between px-5 sm:px-8 py-6" style="position:relative">
        <a href="/" class="t-label flex items-center gap-2" style="color: var(--text-primary)" aria-label="Velucid home">
          <img src="/icon.svg" alt="" width="32" height="32" aria-hidden="true" style="flex-shrink:0;display:block" />
          Velucid
        </a>
        <span class="t-eyebrow" style="position:absolute;left:50%;transform:translateX(-50%)">Delivery Forecasting / v0.1</span>
        <a href="/auth/login" class="t-label" style="color: var(--text-primary)">
          Start Using Velucid →
        </a>
      </div>
    </header>

    <!-- ── HERO ── -->
    <section class="px-5 sm:px-8 py-20 sm:py-32">
      <div class="mx-auto max-w-4xl">
        <div class="t-eyebrow mb-10">Delivery forecasting</div>
        <h1 class="t-hero">
          <span class="tw" data-typewriter data-tw-speed="80" data-tw-delay="200">Know</span> when<br />it <span class="tw" data-typewriter data-tw-speed="80" data-tw-delay="200">ships</span>.
        </h1>
        <div class="mt-10 max-w-2xl t-subhead space-y-5">
          <p>
            Velucid turns your team's real delivery data into probability-based forecasts — continuously updated, always honest about uncertainty.
          </p>
          <p data-tw-speed="40" data-tw-delay="1900">
            Not a date. A confidence range.
          </p>
        </div>
        <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-3">
          <a href="/auth/login" class="cta cta-primary">Start Using Velucid →</a>
          <a href="#the-forecast" class="cta cta-secondary">See the forecast</a>
        </div>
      </div>
    </section>

    <!-- ── SECTION 01: The Forecast ── -->
    <section id="the-forecast" class="hairline border-t section-surface px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <div class="t-eyebrow mb-10">Example forecast · 14-item backlog</div>
        <div class="grid grid-cols-1 sm:grid-cols-3" style="border: 0.5px solid var(--border-strong);">
          <div class="stat-grid-cell">
            <div class="stat-label">50% likely by</div>
            <div class="stat-val">Jun 8</div>
            <div class="stat-hint">Median delivery estimate</div>
          </div>
          <div class="reveal stat-grid-cell">
            <div class="stat-label">70% likely by</div>
            <div class="stat-val">Jun 20</div>
            <div class="stat-hint">Recommended commitment date</div>
          </div>
          <div class="stat-grid-cell">
            <div class="stat-label">95% likely by</div>
            <div class="stat-val">Jul 3</div>
            <div class="stat-hint">Conservative planning buffer</div>
          </div>
        </div>
        <p class="mt-10 t-subhead max-w-2xl">
          Continuously updated from your team's actual throughput. Give stakeholders confidence ranges, not guesses.
        </p>
      </div>
    </section>

    <!-- ── SECTION 02: What you get ── -->
    <section class="hairline border-t px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <h2 class="t-h2">Manage the <span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="0">work</span>.<br />See the <span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="400">forecast</span>.</h2>
        <div class="mt-10 t-subhead space-y-8 max-w-2xl">
          <p>
            Backlog, board, tags, and delivery forecasting in one focused workspace. Track work, get probabilities.
          </p>
          <p>
            No estimation sessions. No ceremony. Your team's actual delivery history is the only input the model needs.
          </p>
        </div>
      </div>
    </section>

    <!-- ── SECTION 03: Proven ── -->
    <section class="hairline border-t px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <h2 class="t-h2"><span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="0">Decades</span> of <span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="600">proof</span></h2>
        <div class="mt-10 t-subhead space-y-8 max-w-2xl">
          <p>
            The forecasting behind Velucid draws on techniques used in finance, supply chain, and aerospace — fields where uncertainty is expensive and guessing isn't an option.
          </p>
          <p>
            We applied the same approach to software delivery.
          </p>
        </div>
      </div>
    </section>

    <!-- ── BOTTOM CTA ── -->
    <section class="hairline border-t px-5 sm:px-8 py-24 sm:py-32">
      <div class="mx-auto max-w-4xl text-center">
        <p class="t-h2 mb-10">Do you have enough <span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="0">runway</span> to <span class="tw" data-typewriter data-tw-speed="70" data-tw-delay="500">ship it</span>?</p>
        <a href="/auth/login" class="cta cta-primary">Start using Velucid →</a>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="hairline border-t px-5 sm:px-8 py-12">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 sm:gap-10">
          <!-- Brand -->
          <div class="col-span-2 sm:col-span-3 lg:col-span-1 space-y-6">
            <div class="t-label" style="color: var(--text-primary)">Velucid</div>
            <div>
              <div class="t-label mb-3">Social</div>
              <div class="flex flex-wrap gap-2">
                <a href="#" class="pill">YouTube</a>
                <a href="#" class="pill">X</a>
                <a href="#" class="pill">LinkedIn</a>
                <a href="#" class="pill">GitHub</a>
              </div>
            </div>
          </div>

          <!-- Column: Product -->
          <div>
            <div class="t-label mb-4">Product</div>
            <ul class="space-y-2 t-body">
              <li><a href="#the-forecast" class="footer-link">Forecasting</a></li>
              <li><a href="#" class="footer-link">Boards</a></li>
              <li><a href="#" class="footer-link">Backlog</a></li>
              <li><a href="#" class="footer-link">Tags</a></li>
              <li><a href="#" class="footer-link">Changelog</a></li>
            </ul>
          </div>

          <!-- Column: Approach -->
          <div>
            <div class="t-label mb-4">Approach</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">How it works</a></li>
              <li><a href="#" class="footer-link">About</a></li>
            </ul>
          </div>

          <!-- Column: Resources -->
          <div>
            <div class="t-label mb-4">Resources</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">Documentation</a></li>
              <li><a href="#" class="footer-link">API</a></li>
              <li><a href="#" class="footer-link">Status</a></li>
              <li><a href="#" class="footer-link">Support</a></li>
            </ul>
          </div>

          <!-- Column: Legal -->
          <div>
            <div class="t-label mb-4">Legal</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">License</a></li>
              <li><a href="#" class="footer-link">Privacy</a></li>
              <li><a href="#" class="footer-link">Terms</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-6 border-t hairline flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <span class="t-label">&copy; {new Date().getFullYear()} Velucid</span>
          <span class="t-label">Know when it ships</span>
        </div>
      </div>
    </footer>

    <script>
      (function () {
        const REDUCE_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (REDUCE_MOTION) return; // CSS @media query handles the visible state
        const els = document.querySelectorAll<HTMLElement>('[data-typewriter]');
        function reveal(el: HTMLElement) {
          const chars = (el.textContent ?? '').trim().length;
          if (chars === 0) return;
          const dur = chars * (parseInt(el.dataset.twSpeed ?? '80', 10));
          const delay = parseInt(el.dataset.twDelay ?? '0', 10);
          el.animate(
            [{ backgroundSize: '0% 100%' }, { backgroundSize: '100% 100%' }],
            {
              duration: dur,
              delay: delay,
              fill: 'forwards',
              easing: `steps(${chars}, end)`,
            },
          );
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                reveal(el);
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.3 },
        );
        els.forEach((el) => io.observe(el));
        // Safety net: if anything prevents the Web Animations path
        // from completing (rare browser bug, etc.), force-reveal after 5s.
        setTimeout(() => {
          els.forEach((el) => {
            el.style.backgroundSize = '100% 100%';
          });
        }, 5000);
      })();
    </script>
  </body>
</html>
