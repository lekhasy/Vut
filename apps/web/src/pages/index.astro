---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Velucid is a project management tool that tells you when work will actually ship — as a probability range from your team's real throughput, not a date invented in a planning meeting."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Velucid — Forecasting that respects the math.</title>
    <style>
      /* ── Industrial UI typography per design-artifacts/D-Design-System/DesignGuideline.html
            Barlow Condensed · weights 400/600/700 only · tracking inversion · caps discipline ── */
      .landing-body {
        font-family: 'Barlow Condensed', sans-serif;
        background: #fff;
        color: #0a0a0a;
        -webkit-font-smoothing: antialiased;
        font-size: 15px;
        line-height: 1.5;
      }

      /* Hairline borders (0.5px) */
      .hairline { border-color: rgba(0, 0, 0, 0.08); }
      .hairline-strong { border-color: rgba(0, 0, 0, 0.16); }

      /* ── Type scale (R-01, R-02, R-03, R-04) ── */

      .t-hero {
        font-size: clamp(44px, 7vw, 80px);
        font-weight: 700;
        letter-spacing: 0.02em;
        line-height: 0.93;
        text-transform: uppercase;
        color: #0a0a0a;
      }

      .t-closer {
        font-size: clamp(32px, 5.5vw, 64px);
        font-weight: 700;
        letter-spacing: 0.02em;
        line-height: 0.98;
        text-transform: uppercase;
        color: #0a0a0a;
      }

      .t-h2 {
        font-size: clamp(32px, 5vw, 48px);
        font-weight: 700;
        letter-spacing: 0.03em;
        line-height: 1.0;
        text-transform: uppercase;
        color: #0a0a0a;
      }

      .t-h3 {
        font-size: 26px;
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.05;
        text-transform: uppercase;
        color: #0a0a0a;
      }

      .t-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.16em;
        line-height: 1;
        text-transform: uppercase;
        color: #888884;
      }

      .t-eyebrow {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.18em;
        line-height: 1;
        text-transform: uppercase;
        color: #888884;
      }

      .t-subhead {
        font-size: 18px;
        font-weight: 400;
        letter-spacing: 0.01em;
        line-height: 1.6;
        color: #444442;
      }

      .t-body {
        font-size: 15px;
        font-weight: 400;
        letter-spacing: 0.01em;
        line-height: 1.5;
        color: #444442;
      }

      /* ── Typographic reveal — left-to-right character sweep ──
         Applied to the 5 named elements only. Falls back to
         final state when scroll-driven animations unsupported. */
      @keyframes reveal {
        from { clip-path: inset(0 100% 0 0); }
        to   { clip-path: inset(0 0 0 0); }
      }
      .reveal {
        clip-path: inset(0 0 0 0);
      }
      @supports (animation-timeline: view()) {
        .reveal {
          animation: reveal linear both;
          animation-timeline: view();
          animation-range: entry 0% entry 60%;
        }
      }

      /* ── Plain rectangular CTA (R-04: weight 600, tracking 0.12em) ── */
      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 22px;
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.12em;
        line-height: 1;
        text-transform: uppercase;
        border-radius: 0;
        transition: background-color 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out;
        text-decoration: none;
        cursor: pointer;
      }
      .cta-primary {
        background: #0a0a0a;
        color: #f0f0ee;
        border: 1px solid #0a0a0a;
      }
      .cta-primary:hover {
        background: #2a2a2a;
        border-color: #2a2a2a;
      }
      .cta-secondary {
        background: transparent;
        color: #0a0a0a;
        border: 1px solid #0a0a0a;
      }
      .cta-secondary:hover {
        background: #0a0a0a;
        color: #f0f0ee;
      }

      /* ── Pills (region, social) ── */
      .pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #444442;
        background: transparent;
        border: 0.5px solid rgba(0, 0, 0, 0.16);
        border-radius: 999px;
        text-decoration: none;
        transition: background-color 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out;
      }
      a.pill:hover {
        background: #0a0a0a;
        color: #f0f0ee;
        border-color: #0a0a0a;
      }

      /* ── Stat block (per design system demo-stats pattern) ── */
      .stat-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.14em;
        line-height: 1;
        text-transform: uppercase;
        color: #888884;
        margin-bottom: 8px;
      }
      .stat-val {
        font-size: clamp(28px, 4vw, 36px);
        font-weight: 700;
        letter-spacing: 0.01em;
        line-height: 1;
        color: #0a0a0a;
      }
      .stat-unit {
        font-size: 14px;
        font-weight: 400;
        color: #444442;
        margin-left: 4px;
      }

      /* Footer link color */
      .footer-link {
        color: #444442;
        text-decoration: none;
        transition: color 150ms ease-out;
      }
      .footer-link:hover { color: #0a0a0a; }
    </style>
  </head>
  <body class="landing-body min-h-screen overflow-x-hidden">

    <!-- ── TOP BAR ── -->
    <header class="border-b hairline">
      <div class="mx-auto max-w-6xl flex items-center justify-between px-5 sm:px-8 py-5">
        <a href="/" class="t-label" style="color: #0a0a0a" aria-label="Velucid home">
          Velucid
        </a>
        <a href="/auth/login" class="t-label" style="color: #0a0a0a">
          Try Velucid →
        </a>
      </div>
    </header>

    <!-- ── HERO ── -->
    <section class="px-5 sm:px-8 py-20 sm:py-32">
      <div class="mx-auto max-w-4xl">
        <div class="t-eyebrow mb-10">Project management · Forecasting</div>
        <h1 class="t-hero">
          Your last delivery date was wrong.
          <br />
          So was the one before it.
        </h1>
        <div class="mt-10 max-w-2xl t-subhead space-y-5">
          <p>
            Every project management tool asks you to predict the future. Then it tracks how wrong you were. Then it asks you to predict again.
          </p>
          <p>
            Velucid works differently. It watches how your team actually delivers work, builds a model from that data, and gives you the odds — not a date someone invented in a planning session.
          </p>
          <p>
            Not a guess. A forecast. There's a difference.
          </p>
        </div>
        <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-3">
          <a href="/auth/login" class="cta cta-primary">Try Velucid →</a>
          <a href="#what-is-here" class="cta cta-secondary">See how it works</a>
        </div>
      </div>
    </section>

    <!-- ── SECTION 01: What's not here ── -->
    <section class="hairline border-t px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <h2 class="reveal t-h2">What's not here</h2>
        <div class="mt-10 t-subhead space-y-8 max-w-2xl">
          <p>
            Story points. Sprint planning. Velocity charts. Burndown graphs. Three-hour meetings to assign numbers to work before it starts.
          </p>
          <p>
            These aren't missing features. They're deliberate decisions.
          </p>
        </div>
      </div>
    </section>

    <!-- ── SECTION 02: What is here ── -->
    <section id="what-is-here" class="hairline border-t px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <h2 class="reveal t-h2">What is here</h2>
        <div class="mt-10 t-subhead space-y-8 max-w-2xl">
          <p>
            A board to track your work. A backlog to organize it. And a forecasting engine that measures how fast work actually flows through your team.
          </p>
          <p>
            Ask it when a feature will ship. It gives you a range of dates, each with a probability. Those numbers come from your team's real data — not a meeting.
          </p>
        </div>

        <!-- Stat block: 70% likely by Mar 20 gets the reveal -->
        <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-10">
          <div>
            <div class="stat-label">50/50 forecast</div>
            <div class="stat-val">Jun 8</div>
          </div>
          <div class="reveal">
            <div class="stat-label">70% likely by</div>
            <div class="stat-val">Mar 20</div>
          </div>
          <div>
            <div class="stat-label">95% likely by</div>
            <div class="stat-val">Apr 3</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SECTION 03: Why this works ── -->
    <section class="hairline border-t px-5 sm:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl">
        <h2 class="reveal t-h2">Why this works</h2>
        <div class="mt-10 t-subhead space-y-8 max-w-2xl">
          <p>
            Probability-based forecasting isn't a new idea. Financial institutions use it to model risk. Supply chains use it to predict delivery windows. Engineering projects in every other industry use it to manage uncertainty honestly.
          </p>
          <p>
            Software teams are late to adopt it. Velucid is the tool that brings it to your backlog.
          </p>
        </div>
      </div>
    </section>

    <!-- ── CLOSER ── -->
    <section class="hairline border-t px-5 sm:px-8 py-24 sm:py-32">
      <div class="mx-auto max-w-4xl">
        <div class="t-eyebrow mb-10">— Closer</div>
        <p class="reveal t-closer">
          The only thing Velucid asks you to give up is the part that was never working anyway.
        </p>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="hairline border-t px-5 sm:px-8 py-12">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 sm:gap-10">
          <!-- Brand -->
          <div class="col-span-2 sm:col-span-3 lg:col-span-1 space-y-6">
            <div class="t-label" style="color: #0a0a0a">Velucid</div>
            <div>
              <div class="t-label mb-3">Social</div>
              <div class="flex flex-wrap gap-2">
                <a href="#" class="pill">YouTube</a>
                <a href="#" class="pill">X</a>
                <a href="#" class="pill">LinkedIn</a>
                <a href="#" class="pill">GitHub</a>
              </div>
            </div>
          </div>

          <!-- Column: Product -->
          <div>
            <div class="t-label mb-4">Product</div>
            <ul class="space-y-2 t-body">
              <li><a href="#what-is-here" class="footer-link">Forecasting</a></li>
              <li><a href="#" class="footer-link">Boards</a></li>
              <li><a href="#" class="footer-link">Backlog</a></li>
              <li><a href="#" class="footer-link">Tags</a></li>
              <li><a href="#" class="footer-link">Changelog</a></li>
            </ul>
          </div>

          <!-- Column: Approach -->
          <div>
            <div class="t-label mb-4">Approach</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">Why this works</a></li>
              <li><a href="#" class="footer-link">For the skeptic</a></li>
              <li><a href="#" class="footer-link">About</a></li>
            </ul>
          </div>

          <!-- Column: Resources -->
          <div>
            <div class="t-label mb-4">Resources</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">Documentation</a></li>
              <li><a href="#" class="footer-link">API</a></li>
              <li><a href="#" class="footer-link">Status</a></li>
              <li><a href="#" class="footer-link">Support</a></li>
            </ul>
          </div>

          <!-- Column: Legal -->
          <div>
            <div class="t-label mb-4">Legal</div>
            <ul class="space-y-2 t-body">
              <li><a href="#" class="footer-link">License</a></li>
              <li><a href="#" class="footer-link">Privacy</a></li>
              <li><a href="#" class="footer-link">Terms</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-6 border-t hairline flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <span class="t-label">&copy; {new Date().getFullYear()} Velucid</span>
          <span class="t-label">Forecasting that respects the math</span>
        </div>
      </div>
    </footer>
  </body>
</html>
