---
interface Props {
  src?: string;
  name: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { src, name, size = 'md', class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'h-6 w-6 text-xs',
  md: 'h-8 w-8 text-sm',
  lg: 'h-10 w-10 text-base',
};

const initials = name
  .split(' ')
  .map((n) => n[0])
  .join('')
  .toUpperCase()
  .slice(0, 2);
---

{src ? (
  <img
    src={src}
    alt={name}
    class:list={['rounded-full object-cover', sizeClasses[size], className]}
  />
) : (
  <span
    class:list={[
      'inline-flex items-center justify-center rounded-full bg-brand-600 text-white font-medium',
      sizeClasses[size],
      className,
    ]}
    role="img"
    aria-label={name}
  >
    {initials}
  </span>
)}
