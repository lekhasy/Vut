{
  "name": "read-model",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/read-model/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:read-model"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run build",
        "cwd": "libs/read-model"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test",
        "cwd": "libs/read-model"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx tsc --noEmit",
        "cwd": "libs/read-model"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx tsc --noEmit",
        "cwd": "libs/read-model"
      }
    }
  }
}
